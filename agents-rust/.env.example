# ATOS Rust agents — environment configuration
#
# In Docker Compose the bootstrap peer is passed as a CLI flag:
#   --bootstrap /ip4/atos-deployer/tcp/4001
# so this env var is only needed when running agents directly (outside Docker).
#
# For local (non-Docker) runs:
#   ATOS_BOOTSTRAP_PEERS=/ip4/127.0.0.1/tcp/4001
# (monitor + governance bootstrap to deployer's libp2p TCP port)

RUST_LOG=info
ATOS_BOOTSTRAP_PEERS=

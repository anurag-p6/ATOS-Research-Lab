# Optional: libp2p bootstrap so monitor/governance dial deployer on the compose network.
# 1) docker compose up -d deployer
# 2) curl -s http://localhost:3001/status   # copy "peerId"
# 3) Put multiaddr below, then: docker compose up -d monitor governance
#
# ATOS_BOOTSTRAP_PEERS=/dns4/deployer/tcp/4001/p2p/<peerId from step 2>

RUST_LOG=info
ATOS_BOOTSTRAP_PEERS=

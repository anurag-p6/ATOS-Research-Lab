# Optional: enables `forge ... --rpc-url sepolia` via foundry.toml [rpc_endpoints]
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Etherscan (Sepolia) — used by `forge verify-contract ... --chain sepolia` / `--verifier etherscan`
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Filecoin Calibration (FEVM testnet, chain id 314159) — public RPC example; override with your provider if needed
FILECOIN_CALIBRATION_RPC_URL=https://api.calibration.node.glif.io/rpc/v1

# Filecoin Butterfly (FEVM testnet, chain id 3141592). Public RPC; use your own endpoint for production-like load tests.
FILECOIN_BUTTERFLY_RPC_URL=https://3141592.rpc.thirdweb.com

# Blockscout key for Calibration verification (many instances accept any non-empty string; try `verify` if unset fails)
FILECOIN_BLOCKSCOUT_API_KEY=verify

# Optional deploy tuning (wei, 18 decimals)
# ATOS_CAP=1000000000000000000000000000
# ATOS_INITIAL_SUPPLY=100000000000000000000000000

# Sepolia ATOSToken address — needed by script/uniswap/seed-pool-sepolia.sh
# ATOS_SEPOLIA=0xYourDeployedATOSAddress

# Sepolia ATOSTokenFactory — deploy once, then set in apps/web/.env as NEXT_PUBLIC_TOKEN_FACTORY_ADDRESS
ATOS_FACTORY_SEPOLIA=0x3284a31bd407dd68c5963ff32ba8770e26796ed7

# Calibration ATOSTokenFactory — set after running script/deploy-factory-calibration.sh
ATOS_FACTORY_CALIBRATION=0x763B23d97471436C5a08b99eFB3c591A887d5335

# Optional Uniswap pool seed tuning (wei, 18 decimals)
# UNI_ATOS_AMOUNT=1000000000000000000000   # 1,000 ATOS
# UNI_WETH_AMOUNT=5000000000000000         # 0.005 WETH
# UNI_FEE=3000                             # 500 | 3000 | 10000
